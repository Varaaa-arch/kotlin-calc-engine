<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#757575"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#000000"
            android:textSize="48sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*">

        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btnMC" android:text="MC" android:backgroundTint="#757575" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnMR" android:text="MR" android:backgroundTint="#757575" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnMPlus" android:text="M+" android:backgroundTint="#757575" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnMMinus" android:text="M-" android:backgroundTint="#757575" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btnAC" android:text="AC" android:backgroundTint="#E0E0E0" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnDel" android:text="DEL" android:backgroundTint="#E0E0E0" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnPercent" android:text="%" android:backgroundTint="#E0E0E0" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnDiv" android:text="÷" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn7" android:text="7" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn8" android:text="8" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn9" android:text="9" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnMul" android:text="×" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn4" android:text="4" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn5" android:text="5" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn6" android:text="6" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnMinus" android:text="-" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow android:layout_marginBottom="8dp">
            <Button android:id="@+id/btn1" android:text="1" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn2" android:text="2" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn3" android:text="3" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnPlus" android:text="+" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow>
            <Button android:id="@+id/btn0" android:text="0" android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp" android:layout_span="2"/>
            <Button android:id="@+id/btnDot" android:text="." android:backgroundTint="#FFFFFF" android:textColor="#000000" android:layout_margin="2dp"/>
            <Button android:id="@+id/btnEqual" android:text="=" android:backgroundTint="#4CAF50" android:textColor="#FFFFFF" android:layout_margin="2dp"/>
        </TableRow>
    </TableLayout>
</LinearLayout>